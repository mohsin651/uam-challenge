data/raw/
data/images/
data/*.zip
data/*.tar*

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Explicitly keep CSVs, logs, configs, md ---
!*.csv
!*.md
!*.yml
!*.yaml
!logs/
!logs/*.log
