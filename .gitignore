# --- Environments ---
.venv/
venv/
env/
.hf_home/
enviroments.sh

# --- Python caches ---
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# --- Model checkpoints / weights (heavy) ---
*.pth
*.pt
*.bin
*.ckpt
